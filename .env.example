# Groq API key used for LLM-based PR review + patch drafting
GROQ_API_KEY=

# GitHub App id used to generate GitHub App JWTs (RS256)
GITHUB_APP_ID=3222129

# GitHub App private key in PEM format (include BEGIN/END lines)
GITHUB_PRIVATE_KEY=

# Secret used to verify GitHub webhook signatures (X-Hub-Signature-256)
GITHUB_WEBHOOK_SECRET=

# Postgres connection string used by LangGraph checkpointing
DATABASE_URL=

# API key used by LangChain integrations (OpenAI embeddings via langchain-openai)
LANGCHAIN_API_KEY=

# LangSmith project name for tracing
LANGSMITH_PROJECT=smart-pr-review-agent

# Persistent directory for Chroma embeddings storage
CHROMA_PERSIST_DIR=./chroma

# GitHub MCP server URL (kept for MCP-based integration options)
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# Frontend origin allowed by CORS
FRONTEND_URL=http://localhost:5173
